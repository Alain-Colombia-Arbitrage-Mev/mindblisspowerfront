# Copy to /etc/mindbliss/frontend.env on the EC2 host.
# Do not commit a filled production file.

NODE_ENV=production

# Next server calls vp-engine from server-side API routes.
VP_ENGINE_HTTP_URL=http://127.0.0.1:9090
LLM_PROVIDER=vp-engine-openrouter

# Cognito direct API auth. The app uses custom login/register/forgot screens.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_8tLjOfPH1
COGNITO_IDENTITY_POOL_ID=us-east-1:3851d951-0dcb-487f-a418-b55de754df8c
COGNITO_CLIENT_ID=CHANGE_ME
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_8tLjOfPH1
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_8tLjOfPH1/.well-known/jwks.json

# Hosted UI is intentionally disabled. Leave blank unless Managed Login is re-enabled.
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=
COGNITO_LOGOUT_URI=https://app.mindblisspower.com/login
COGNITO_SCOPES=openid email profile
